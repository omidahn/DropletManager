<?xml version="1.0" encoding="utf-8"?><!--
   Sample data extraction rules file; uncomment and customize as necessary.
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
   for details.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="secure_prefs.xml" />
        <exclude domain="sharedpref" path="secure_prefs_ssh.xml" />
        <exclude domain="sharedpref" path="secure_known_hosts.xml" />
        <exclude domain="sharedpref" path="androidx.security.crypto.master_key_keyset_prefs.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="secure_prefs.xml" />
        <exclude domain="sharedpref" path="secure_prefs_ssh.xml" />
        <exclude domain="sharedpref" path="secure_known_hosts.xml" />
        <exclude domain="sharedpref" path="androidx.security.crypto.master_key_keyset_prefs.xml" />
    </device-transfer>
</data-extraction-rules>
