<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/ssh_details_title"
        android:textAppearance="@style/TextAppearance.AppCompat.Large"
        android:layout_gravity="center_horizontal"
        android:paddingBottom="8dp"/>

    <TextView
        android:id="@+id/descriptionText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/ssh_details_description"
        android:textAppearance="@style/TextAppearance.AppCompat.Body1"
        android:layout_gravity="center_horizontal"
        android:paddingBottom="16dp"/>

    <TextView
        android:id="@+id/sshCommandText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/ssh_details_command_placeholder"
        android:textAppearance="@style/TextAppearance.AppCompat.Medium"
        android:background="@drawable/ic_copy"
        android:padding="8dp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/ipAddressText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/ssh_details_ip_placeholder"
        android:textAppearance="@style/TextAppearance.AppCompat.Medium"
        android:background="@drawable/ic_copy"
        android:padding="8dp"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        style="?android:attr/buttonBarStyle">

        <Button
            android:id="@+id/copyCommandButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ssh_details_copy_command"
            android:drawableStart="@drawable/ic_copy"
            android:layout_marginEnd="8dp"
            style="?android:attr/buttonBarButtonStyle"/>

        <Button
            android:id="@+id/copyIpButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ssh_details_copy_ip"
            android:drawableStart="@drawable/ic_copy"
            style="?android:attr/buttonBarButtonStyle"/>

    </LinearLayout>

</LinearLayout>
