<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/dropletName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:textAppearance="?attr/textAppearanceSubtitle1"
                android:textColor="?attr/colorOnSurface"
                tools:text="Droplet Name" />

            <com.google.android.material.chip.Chip
                android:id="@+id/statusChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textAppearance="?attr/textAppearanceBody2"
                app:chipMinHeight="32dp"
                app:chipIcon="@drawable/ic_power"
                tools:text="Active" />
        </LinearLayout>

        <TextView
            android:id="@+id/dropletRegion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="?attr/textAppearanceBody2"
            android:textColor="?attr/colorSecondary"
            tools:text="New York" />

        <TextView
            android:id="@+id/dropletCreated"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textAppearance="?attr/textAppearanceCaption"
            tools:text="Created: 2025-08-23" />

        <TextView
            android:id="@+id/dropletSpecs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="?attr/textAppearanceBody2"
            tools:text="2GB RAM • 1 CPU • 50GB Disk" />

        <TextView
            android:id="@+id/dropletCost"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="?attr/textAppearanceBody2"
            android:textColor="?attr/colorPrimary"
            tools:text="$10/mo + $2 backups" />

        <TextView
            android:id="@+id/dropletHourlyCost"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textAppearance="?attr/textAppearanceCaption"
            android:textColor="?attr/colorPrimary"
            android:visibility="gone"
            tools:text="$0.015/hour" />

        <TextView
            android:id="@+id/dropletIp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textAppearance="?attr/textAppearanceCaption"
            android:textColor="?attr/colorOnSurface"
            android:visibility="gone"
            tools:text="IP: 192.168.1.1" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/actionsChipGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:singleLine="false"
            android:horizontalSpacing="8dp"
            android:verticalSpacing="8dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/powerChip"
                style="@style/Widget.MaterialComponents.Chip.Action"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:chipIcon="@drawable/ic_power"
                android:text="@string/start" />

            <com.google.android.material.chip.Chip
                android:id="@+id/rebootChip"
                style="@style/Widget.MaterialComponents.Chip.Action"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reboot"
                app:chipIcon="@drawable/ic_refresh" />

            <com.google.android.material.chip.Chip
                android:id="@+id/snapshotChip"
                style="@style/Widget.MaterialComponents.Chip.Action"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/create_snapshot"
                app:chipIcon="@drawable/ic_snapshot" />

            <com.google.android.material.chip.Chip
                android:id="@+id/backupChip"
                style="@style/Widget.MaterialComponents.Chip.Action"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/create_backup"
                app:chipIcon="@drawable/ic_backup" />

            <com.google.android.material.chip.Chip
                android:id="@+id/sshChip"
                style="@style/Widget.MaterialComponents.Chip.Action"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ssh_access"
                app:chipIcon="@drawable/ic_terminal" />
        </com.google.android.material.chip.ChipGroup>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
